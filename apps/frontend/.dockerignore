# Node modules (these will be installed during the Docker build process)
node_modules
**/node_modules

# Dependency lock files (if you're using Yarn or PNPM, exclude the others)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build output directories
/build
/dist
/.next
/.cache
/.turbo
/.parcel-cache
/apps/*/build
/apps/*/dist

# Environment files
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Log files
*.log
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS-generated files
.DS_Store
Thumbs.db

# Git files
.git
.gitignore

# IDE/editor files
.idea
.vscode
*.swp

# Coverage output (if you use a testing framework)
coverage
*.lcov

# Temporary files
tmp
temp
*.tmp

# Ignore test and documentation files
__tests__
test
tests
*.test.js
*.spec.js
docs
*.md

# Ignore Docker-specific files
Dockerfile*
.dockerignore
docker-compose.yml

# Exclude Turbo repo cache and output if using Turborepo
.turbo
out
